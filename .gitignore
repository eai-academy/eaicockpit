# eAI Cockpit — .gitignore

# --- Dados locais gerados (NUNCA commitar) ---
.eaicockpit/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/
.Python
pip-wheel-metadata/
*.whl
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Frontend ---
frontend/node_modules/
frontend/dist/
frontend/.vite/

# --- Segredos e configuração local (CRÍTICO) ---
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# --- Logs ---
*.log
logs/

# --- SO ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Temporários ---
*.tmp
*.bak
*.orig
